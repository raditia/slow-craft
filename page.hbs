{{!< default}}

{{#post}}
<main class="bc-main">

    {{#match slug "about"}}
        <div class="bc-container bc-container--about">
            <div class="bc-about-head bc-reveal">
                {{#if primary_author.profile_image}}
                    <img class="bc-about-portrait" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}">
                {{/if}}
                <span class="bc-tag-label">{{t "About"}}</span>
                <h1 class="bc-about-title">{{title}}</h1>
            </div>
            <div class="bc-about-content gh-content bc-reveal">
                {{content}}
            </div>
            <div class="bc-about-social bc-reveal">
                {{#primary_author}}
                    {{#if twitter}}
                        <a class="bc-about-social-link" href="{{social_url type="twitter"}}" target="_blank" rel="noopener" aria-label="Twitter">{{> "icons/twitter"}}</a>
                    {{/if}}
                    {{#if facebook}}
                        <a class="bc-about-social-link" href="{{social_url type="facebook"}}" target="_blank" rel="noopener" aria-label="Facebook">{{> "icons/facebook"}}</a>
                    {{/if}}
                    {{#if linkedin}}
                        <a class="bc-about-social-link" href="{{social_url type="linkedin"}}" target="_blank" rel="noopener" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
                    {{/if}}
                    {{#if instagram}}
                        <a class="bc-about-social-link" href="{{social_url type="instagram"}}" target="_blank" rel="noopener" aria-label="Instagram">{{> "icons/instagram"}}</a>
                    {{/if}}
                    {{#if bluesky}}
                        <a class="bc-about-social-link" href="{{social_url type="bluesky"}}" target="_blank" rel="noopener" aria-label="Bluesky">{{> "icons/bluesky"}}</a>
                    {{/if}}
                    {{#if threads}}
                        <a class="bc-about-social-link" href="{{social_url type="threads"}}" target="_blank" rel="noopener" aria-label="Threads">{{> "icons/threads"}}</a>
                    {{/if}}
                    {{#if mastodon}}
                        <a class="bc-about-social-link" href="{{social_url type="mastodon"}}" target="_blank" rel="noopener" aria-label="Mastodon">{{> "icons/mastodon"}}</a>
                    {{/if}}
                    {{#if tiktok}}
                        <a class="bc-about-social-link" href="{{social_url type="tiktok"}}" target="_blank" rel="noopener" aria-label="TikTok">{{> "icons/tiktok"}}</a>
                    {{/if}}
                    {{#if youtube}}
                        <a class="bc-about-social-link" href="{{social_url type="youtube"}}" target="_blank" rel="noopener" aria-label="YouTube">{{> "icons/youtube"}}</a>
                    {{/if}}
                    {{#if website}}
                        <a class="bc-about-social-link" href="{{website}}" target="_blank" rel="noopener" aria-label="Website">{{> "icons/website"}}</a>
                    {{/if}}
                {{/primary_author}}
            </div>
        </div>
    {{else}}
        <article class="bc-article">
            <div class="bc-container bc-container--article">
                {{#match @page.show_title_and_feature_image}}
                    <header class="bc-article-header">
                        <h1 class="bc-article-title">{{title}}</h1>
                        {{#if custom_excerpt}}
                            <p class="bc-article-excerpt">{{custom_excerpt}}</p>
                        {{/if}}
                    </header>
                    {{#if feature_image}}
                        <figure class="bc-article-image">
                            <img
                                srcset="{{img_url feature_image size="m"}} 720w,
                                        {{img_url feature_image size="l"}} 960w,
                                        {{img_url feature_image size="xl"}} 1200w"
                                sizes="(max-width: 760px) 100vw, 760px"
                                src="{{img_url feature_image size="l"}}"
                                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            >
                        </figure>
                    {{/if}}
                {{/match}}
                <section class="bc-article-content gh-content">
                    {{content}}
                </section>
            </div>
        </article>
    {{/match}}

</main>
{{/post}}
