<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}}">
<div class="bc-site">

    <header class="bc-header" id="bc-head">
        <div class="bc-header-inner">
            <a class="bc-logo" href="{{@site.url}}">
                <span class="bc-logo-mark"></span>
                {{#if @site.logo}}
                    <img class="bc-logo-img" src="{{@site.logo}}" alt="{{@site.title}}">
                {{else}}
                    <span class="bc-logo-name">{{@site.title}}</span>
                {{/if}}
            </a>

            <nav class="bc-nav" aria-label="{{t "Main navigation"}}">
                {{navigation}}
                <span class="bc-nav-sep" aria-hidden="true"></span>
                <button class="bc-search-btn" aria-label="{{t "Search this site"}}" data-ghost-search>
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path></svg>
                </button>
                {{#if @site.members_enabled}}
                    {{#unless @member}}
                        {{#unless @site.members_invite_only}}
                            <a class="bc-subscribe-btn" href="#/portal/signup" data-portal="signup">{{t "Subscribe"}}</a>
                        {{/unless}}
                    {{else}}
                        <a class="bc-subscribe-btn" href="#/portal/account" data-portal="account">{{t "Account"}}</a>
                    {{/unless}}
                {{/if}}
            </nav>

            <button class="bc-burger" aria-label="{{t "Toggle menu"}}" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </div>

        <nav class="bc-mobile-nav" aria-label="{{t "Mobile navigation"}}">
            {{navigation}}
            {{#if @site.members_enabled}}
                {{#unless @member}}
                    {{#unless @site.members_invite_only}}
                        <a class="bc-mobile-subscribe" href="#/portal/signup" data-portal="signup">{{t "Subscribe"}}</a>
                    {{/unless}}
                {{/unless}}
            {{/if}}
        </nav>
    </header>

    {{{body}}}

    <footer class="bc-footer">
        <div class="bc-footer-inner">
            <div class="bc-footer-brand">
                <div class="bc-footer-logo">
                    <span class="bc-logo-mark bc-logo-mark--sm"></span>
                    <span class="bc-footer-logo-name">{{@site.title}}</span>
                </div>
                <p class="bc-footer-copy">&copy; {{date format="YYYY"}} {{@site.title}}. {{{t "Powered by {ghostlink}" ghostlink="<a href=\"https://ghost.org/\" target=\"_blank\" rel=\"noopener\">Ghost</a>"}}}</p>
            </div>
            <nav class="bc-footer-nav" aria-label="{{t "Footer navigation"}}">
                {{navigation}}
            </nav>
        </div>
    </footer>

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}"></script>
{{ghost_foot}}

</body>
</html>
