{{!< default}}

<main class="bc-main">
    <div class="bc-container">

        {{! Hero }}
        <div class="bc-hero bc-reveal">
            <h1 class="bc-hero-headline" id="bc-hero-headline">{{#if @site.description}}{{@site.description}}{{else}}Notes on software, attention, and the slow craft of building things.{{/if}}</h1>
            <p class="bc-hero-subtitle" id="bc-hero-subtitle">Written by someone who is, quite often, productively bored.</p>
        </div>

        <script>
        (function () {
            function pickRandom(text) {
                var lines = text.split('|').map(function(l){ return l.trim(); }).filter(Boolean);
                return lines.length ? lines[Math.floor(Math.random() * lines.length)] : null;
            }
            var headlines = {{json @custom.hero_headlines}};
            var subtitles = {{json @custom.hero_subtitles}};
            var picked;
            if (headlines && (picked = pickRandom(headlines))) {
                var h = document.getElementById('bc-hero-headline');
                if (h) h.textContent = picked;
            }
            if (subtitles && (picked = pickRandom(subtitles))) {
                var s = document.getElementById('bc-hero-subtitle');
                if (s) s.textContent = picked;
            }
        })();
        </script>

        {{! ================================================================
            Featured post — prefer Ghost "featured" flag, fallback to newest.
            Each branch owns its section header + grid so "from" can differ.
            ================================================================ }}

        {{#get "posts" filter="tag:-til+featured:true" limit="1" include="authors,tags"}}
            {{#if posts}}

            {{! Featured post exists }}
            {{#foreach posts}}
            {{#if feature_image}}
            <a class="bc-featured bc-reveal" href="{{url}}">
                <div class="bc-featured-image">
                    <img
                        srcset="{{img_url feature_image size="m"}} 720w,
                                {{img_url feature_image size="l"}} 960w,
                                {{img_url feature_image size="xl"}} 1200w"
                        sizes="(max-width: 991px) 100vw, 55vw"
                        src="{{img_url feature_image size="l"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    >
                </div>
                <div class="bc-featured-content">
                    <span class="bc-featured-kicker">{{#if primary_tag}}{{primary_tag.name}} · {{/if}}Featured</span>
                    <h2 class="bc-featured-title">{{title}}</h2>
                    {{#if custom_excerpt}}<p class="bc-featured-excerpt">{{custom_excerpt}}</p>
                    {{else if excerpt}}<p class="bc-featured-excerpt">{{excerpt}}</p>{{/if}}
                    <div class="bc-post-meta">
                        <span class="bc-post-meta-author">{{primary_author.name}}</span>
                        <span class="bc-meta-dot"></span>
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        <span class="bc-meta-dot"></span>
                        <span>{{reading_time}}</span>
                    </div>
                    <span class="bc-featured-read">Read article →</span>
                </div>
            </a>
            {{else}}
            <a class="bc-featured-typo bc-reveal" href="{{url}}">
                {{#if primary_tag}}<span class="bc-featured-typo-letter" aria-hidden="true">{{primary_tag.name}}</span>{{/if}}
                <div class="bc-featured-typo-inner">
                    <span class="bc-featured-typo-kicker">Featured{{#if primary_tag}} · {{primary_tag.name}}{{/if}}</span>
                    <h2 class="bc-featured-typo-title">{{title}}</h2>
                    {{#if custom_excerpt}}<p class="bc-featured-typo-excerpt">{{custom_excerpt}}</p>
                    {{else if excerpt}}<p class="bc-featured-typo-excerpt">{{excerpt}}</p>{{/if}}
                    <div class="bc-post-meta bc-post-meta--dark">
                        <span class="bc-post-meta-author">{{primary_author.name}}</span>
                        <span class="bc-meta-dot bc-meta-dot--dark"></span>
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        <span class="bc-meta-dot bc-meta-dot--dark"></span>
                        <span>{{reading_time}}</span>
                    </div>
                    <span class="bc-featured-read bc-featured-read--dark">Read article →</span>
                </div>
            </a>
            {{/if}}
            {{/foreach}}

            {{! Recent — show newest 3 posts (featured hero is separate) }}
            <div class="bc-section-header bc-reveal">
                <h2 class="bc-section-label">{{t "Recent"}}</h2>
                <a class="bc-section-link" href="{{#if @custom.writing_page_url}}{{@custom.writing_page_url}}{{else}}{{@site.url}}/writing{{/if}}">{{t "All writing"}} &rarr;</a>
            </div>
            <div class="bc-grid bc-grid--3">
                {{#get "posts" filter="tag:-til" limit="3" include="authors,tags"}}
                    {{#foreach posts}}
                        {{> "loop-grid"}}
                    {{/foreach}}
                {{/get}}
            </div>

            {{else}}

            {{! No featured post — show newest as hero }}
            {{#get "posts" filter="tag:-til" limit="1" include="authors,tags"}}
                {{#foreach posts}}
                {{#if feature_image}}
                <a class="bc-featured bc-reveal" href="{{url}}">
                    <div class="bc-featured-image">
                        <img
                            srcset="{{img_url feature_image size="m"}} 720w,
                                    {{img_url feature_image size="l"}} 960w,
                                    {{img_url feature_image size="xl"}} 1200w"
                            sizes="(max-width: 991px) 100vw, 55vw"
                            src="{{img_url feature_image size="l"}}"
                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                        >
                    </div>
                    <div class="bc-featured-content">
                        {{#if primary_tag}}<span class="bc-featured-kicker">{{primary_tag.name}}</span>{{/if}}
                        <h2 class="bc-featured-title">{{title}}</h2>
                        {{#if custom_excerpt}}<p class="bc-featured-excerpt">{{custom_excerpt}}</p>
                        {{else if excerpt}}<p class="bc-featured-excerpt">{{excerpt}}</p>{{/if}}
                        <div class="bc-post-meta">
                            <span class="bc-post-meta-author">{{primary_author.name}}</span>
                            <span class="bc-meta-dot"></span>
                            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                            <span class="bc-meta-dot"></span>
                            <span>{{reading_time}}</span>
                        </div>
                    </div>
                </a>
                {{else}}
                <a class="bc-featured-typo bc-reveal" href="{{url}}">
                    {{#if primary_tag}}<span class="bc-featured-typo-letter" aria-hidden="true">{{primary_tag.name}}</span>{{/if}}
                    <div class="bc-featured-typo-inner">
                        {{#if primary_tag}}<span class="bc-featured-typo-kicker">{{primary_tag.name}}</span>{{/if}}
                        <h2 class="bc-featured-typo-title">{{title}}</h2>
                        {{#if custom_excerpt}}<p class="bc-featured-typo-excerpt">{{custom_excerpt}}</p>
                        {{else if excerpt}}<p class="bc-featured-typo-excerpt">{{excerpt}}</p>{{/if}}
                        <div class="bc-post-meta bc-post-meta--dark">
                            <span class="bc-post-meta-author">{{primary_author.name}}</span>
                            <span class="bc-meta-dot bc-meta-dot--dark"></span>
                            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                            <span class="bc-meta-dot bc-meta-dot--dark"></span>
                            <span>{{reading_time}}</span>
                        </div>
                    </div>
                </a>
                {{/if}}
                {{/foreach}}
            {{/get}}

            {{! Recent — skip post 1 (shown as hero above) }}
            <div class="bc-section-header bc-reveal">
                <h2 class="bc-section-label">{{t "Recent"}}</h2>
                <a class="bc-section-link" href="{{#if @custom.writing_page_url}}{{@custom.writing_page_url}}{{else}}{{@site.url}}/writing{{/if}}">{{t "All writing"}} &rarr;</a>
            </div>
            <div class="bc-grid bc-grid--3">
                {{#get "posts" filter="tag:-til" limit="4" include="authors,tags"}}
                    {{#foreach posts from="2"}}
                        {{> "loop-grid"}}
                    {{/foreach}}
                {{/get}}
            </div>

            {{/if}}
        {{/get}}

        {{! Newsletter strip }}
        {{#if @site.members_enabled}}
        <div class="bc-newsletter-band bc-reveal">
            <div class="bc-newsletter-band-left">
                <div class="bc-newsletter-band-label">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#B0532B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M2 7l10 7 10-7"></path></svg>
                    <span>{{t "Newsletter"}}</span>
                </div>
                <h2 class="bc-newsletter-band-title">{{t "A slow letter, once a month."}}</h2>
                <p class="bc-newsletter-band-desc">{{t "What I've been building, reading, and thinking about. No cadence pressure — only when there's something worth saying."}}</p>
            </div>
            <div class="bc-newsletter-band-right">
                <input type="email" placeholder="{{t "your@email.com"}}" class="bc-newsletter-band-input" data-members-email>
                <button class="bc-newsletter-band-btn" data-members-submit>{{t "Subscribe"}} &rarr;</button>
                <span class="bc-newsletter-band-note">{{t "No spam. Unsubscribe whenever."}}</span>
            </div>
        </div>
        {{/if}}

        {{! Archive }}
        <div class="bc-archive-header bc-reveal">
            <h2 class="bc-section-label">{{t "From the archive"}}</h2>
        </div>

        <div class="bc-archive">
            {{#get "posts" filter="tag:-til" limit="12" include="tags"}}
                {{#foreach posts from="5"}}
                    <a class="bc-archive-row bc-reveal" href="{{url}}">
                        {{#if primary_tag}}
                            <span class="bc-tag-label bc-tag-label--sm">{{primary_tag.name}}</span>
                        {{else}}
                            <span class="bc-tag-label bc-tag-label--sm"></span>
                        {{/if}}
                        <h3 class="bc-archive-title">{{title}}</h3>
                        <time class="bc-archive-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                    </a>
                {{/foreach}}
            {{/get}}
        </div>

    </div>
</main>
