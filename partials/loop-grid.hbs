<article class="bc-card bc-reveal">
    <a class="bc-card-link" href="{{url}}">
        <div class="bc-card-image">
            {{#if feature_image}}
                <img
                    srcset="{{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 720w"
                    sizes="(max-width: 767px) 100vw, 33vw"
                    src="{{img_url feature_image size="m"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                >
            {{else}}
                <div class="bc-image-placeholder"></div>
            {{/if}}
        </div>
        {{#if primary_tag}}
            <span class="bc-tag-label bc-tag-label--sm">{{primary_tag.name}}</span>
        {{/if}}
        <h3 class="bc-card-title">{{title}}</h3>
        {{#if custom_excerpt}}
            <p class="bc-card-excerpt">{{custom_excerpt}}</p>
        {{else if excerpt}}
            <p class="bc-card-excerpt">{{excerpt}}</p>
        {{/if}}
        <div class="bc-card-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
            <span class="bc-meta-mid">&middot;</span>
            <span>{{reading_time}}</span>
        </div>
    </a>
</article>
