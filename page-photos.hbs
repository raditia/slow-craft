{{!< default}}

{{#post}}
<main class="bc-main bc-main--v2">

    <div class="bc-page-hero-dark">
        <div class="bc-container">
            <div class="bc-reveal">
                <span class="bc-tag-label">{{t "Photographs"}}</span>
                <h1 class="bc-page-hero-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="bc-page-hero-desc">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </div>

    <div class="bc-container" style="padding-top: 44px;">
        <div class="bc-masonry gh-content">
            {{content}}
        </div>
    </div>

</main>
{{/post}}
