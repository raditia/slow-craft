{{!< default}}

{{#post}}
<main class="bc-main">
    <div class="bc-container">

        <div class="bc-page-head bc-reveal">
            <span class="bc-tag-label">{{t "Photographs"}}</span>
            <h1 class="bc-page-title bc-page-title--large">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="bc-page-description">{{custom_excerpt}}</p>
            {{/if}}
        </div>

        <div class="bc-photos-meta" id="bc-photos-meta" style="display:none">
            <span class="bc-photos-count" id="bc-photos-count"></span>
            <span class="bc-photos-updated">Updated <time id="bc-photos-updated"></time></span>
        </div>

        {{! JS-powered masonry — auto-syncs with Unsplash }}
        <div class="bc-photos-grid" id="bc-photos-grid" aria-label="Photo gallery">
            <div class="bc-photos-loading" id="bc-photos-loading">
                <span class="bc-photos-loading-dot"></span>
                <span class="bc-photos-loading-dot"></span>
                <span class="bc-photos-loading-dot"></span>
            </div>
        </div>

        <div class="bc-photos-error" id="bc-photos-error" style="display:none">
            <p>Photos unavailable. Check back soon.</p>
        </div>

    </div>
</main>

<script>
(function () {
    var UNSPLASH_KEY  = window.UNSPLASH_ACCESS_KEY;
    var UNSPLASH_USER = window.UNSPLASH_USERNAME || 'raditia';
    var PER_PAGE      = window.UNSPLASH_PER_PAGE || 30;
    var CACHE_KEY     = 'bc_photos_cache';
    var CACHE_TTL     = 60 * 60 * 1000; // 1 hour

    var grid    = document.getElementById('bc-photos-grid');
    var loading = document.getElementById('bc-photos-loading');
    var errorEl = document.getElementById('bc-photos-error');

    if (!UNSPLASH_KEY) {
        loading.style.display = 'none';
        errorEl.style.display = 'block';
        console.warn('Missing UNSPLASH_ACCESS_KEY. Add it via Ghost Admin > Code Injection.');
        return;
    }

    var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var img = entry.target;
            var src = img.getAttribute('data-src');
            if (!src) return;
            img.src = src;
            img.removeAttribute('data-src');
            img.addEventListener('load', function () { img.classList.add('bc-photo-loaded'); });
            io.unobserve(img);
        });
    }, { rootMargin: '200px 0px' });

    function showMeta(photos, ts) {
        var metaEl   = document.getElementById('bc-photos-meta');
        var countEl  = document.getElementById('bc-photos-count');
        var timeEl   = document.getElementById('bc-photos-updated');
        var date     = new Date(ts);
        var now      = new Date();
        var diffMin  = Math.floor((now - date) / 60000);
        var timeStr;

        if (diffMin < 1)        timeStr = 'just now';
        else if (diffMin < 60)  timeStr = diffMin + ' min ago';
        else if (diffMin < 1440) timeStr = Math.floor(diffMin / 60) + 'h ago';
        else                    timeStr = date.toLocaleDateString(undefined, { day: 'numeric', month: 'short', year: 'numeric' });

        countEl.textContent = photos.length + ' photo' + (photos.length !== 1 ? 's' : '');
        timeEl.setAttribute('datetime', date.toISOString());
        timeEl.textContent = timeStr;
        metaEl.style.display = 'flex';
    }

    function renderPhotos(photos, ts) {
        loading.style.display = 'none';

        if (!photos.length) {
            errorEl.textContent = 'No photos yet.';
            errorEl.style.display = 'block';
            return;
        }

        showMeta(photos, ts || Date.now());

        photos.forEach(function (photo) {
            var item = document.createElement('div');
            item.className = 'bc-photo-item bc-reveal';

            var link = document.createElement('a');
            link.href = photo.links.html;
            link.target = '_blank';
            link.rel = 'noopener';
            link.setAttribute('aria-label', photo.alt_description || 'Photo by ' + photo.user.name);

            var img = document.createElement('img');
            img.setAttribute('data-src', photo.urls.regular);
            img.alt = photo.alt_description || '';
            img.width = photo.width;
            img.height = photo.height;
            img.className = 'bc-photo-img';
            img.style.aspectRatio = photo.width + ' / ' + photo.height;

            link.appendChild(img);
            item.appendChild(link);
            grid.appendChild(item);
            io.observe(img);
        });

        setTimeout(function () {
            grid.querySelectorAll('.bc-reveal').forEach(function (el, i) {
                setTimeout(function () { el.classList.add('is-visible'); }, i * 40);
            });
        }, 50);
    }

    function getCache() {
        try {
            var raw = localStorage.getItem(CACHE_KEY);
            if (!raw) return null;
            var cached = JSON.parse(raw);
            if (Date.now() - cached.ts > CACHE_TTL) return null;
            return cached.photos;
        } catch (e) {
            return null;
        }
    }

    function setCache(photos) {
        try {
            localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), photos: photos }));
        } catch (e) {
            // localStorage full or blocked — silently skip
        }
    }

    // Serve from cache if fresh
    var cached = getCache();
    if (cached) {
        try {
            var raw = localStorage.getItem(CACHE_KEY);
            var ts  = raw ? JSON.parse(raw).ts : Date.now();
        } catch (e) { var ts = Date.now(); }
        renderPhotos(cached, ts);
        return;
    }

    // Fetch from Unsplash
    fetch('https://api.unsplash.com/users/' + UNSPLASH_USER + '/photos?per_page=' + PER_PAGE + '&order_by=latest&client_id=' + UNSPLASH_KEY)
        .then(function (res) {
            if (res.status === 403) throw new Error('rate_limited');
            if (!res.ok) throw new Error('api_error_' + res.status);
            return res.json();
        })
        .then(function (photos) {
            var ts = Date.now();
            setCache(photos);
            renderPhotos(photos, ts);
        })
        .catch(function (err) {
            loading.style.display = 'none';
            if (err.message === 'rate_limited') {
                errorEl.innerHTML = '<p>Photos are taking a break. <a href="https://unsplash.com/@' + UNSPLASH_USER + '" target="_blank" rel="noopener">View on Unsplash</a> in the meantime.</p>';
            } else {
                errorEl.innerHTML = '<p>Photos unavailable right now. <a href="https://unsplash.com/@' + UNSPLASH_USER + '" target="_blank" rel="noopener">View on Unsplash</a>.</p>';
            }
            errorEl.style.display = 'block';
            console.error('Unsplash fetch failed:', err.message);
        });
})();
</script>
{{/post}}
