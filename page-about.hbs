{{!< default}}

{{#post}}
<main class="bc-main">
    <div class="bc-about-page">

        {{! Top: portrait + intro }}
        <div class="bc-about-top bc-reveal">
            {{#primary_author}}
                {{#if profile_image}}
                    <img class="bc-about-portrait-rect" src="{{profile_image}}" alt="{{name}}">
                {{/if}}
                <div class="bc-about-intro">
                    <span class="bc-tag-label">{{t "About"}}</span>
                    <h1 class="bc-about-page-title">{{../title}}</h1>
                    {{#if bio}}
                        <p class="bc-about-tagline">{{bio}}</p>
                    {{/if}}
                    <div class="bc-about-actions">
                        {{#if @custom.about_email}}
                            <a class="bc-btn bc-btn--primary" href="mailto:{{@custom.about_email}}">{{t "Email me"}}</a>
                        {{/if}}
                        {{! Social icons inline with actions }}
                        <div class="bc-about-actions-social">
                            {{#if @custom.about_github_url}}<a class="bc-about-social-link" href="{{@custom.about_github_url}}" target="_blank" rel="noopener" aria-label="GitHub">{{> "icons/github"}}</a>{{/if}}
                            {{#if twitter}}<a class="bc-about-social-link" href="{{social_url type="twitter"}}" target="_blank" rel="noopener" aria-label="Twitter">{{> "icons/twitter"}}</a>{{/if}}
                            {{#if facebook}}<a class="bc-about-social-link" href="{{social_url type="facebook"}}" target="_blank" rel="noopener" aria-label="Facebook">{{> "icons/facebook"}}</a>{{/if}}
                            {{#if linkedin}}<a class="bc-about-social-link" href="{{social_url type="linkedin"}}" target="_blank" rel="noopener" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>{{/if}}
                            {{#if instagram}}<a class="bc-about-social-link" href="{{social_url type="instagram"}}" target="_blank" rel="noopener" aria-label="Instagram">{{> "icons/instagram"}}</a>{{/if}}
                            {{#if bluesky}}<a class="bc-about-social-link" href="{{social_url type="bluesky"}}" target="_blank" rel="noopener" aria-label="Bluesky">{{> "icons/bluesky"}}</a>{{/if}}
                            {{#if threads}}<a class="bc-about-social-link" href="{{social_url type="threads"}}" target="_blank" rel="noopener" aria-label="Threads">{{> "icons/threads"}}</a>{{/if}}
                            {{#if website}}<a class="bc-about-social-link" href="{{website}}" target="_blank" rel="noopener" aria-label="Website">{{> "icons/website"}}</a>{{/if}}
                        </div>
                    </div>
                </div>
            {{/primary_author}}
        </div>

        {{! Facts grid }}
        <div class="bc-about-facts bc-reveal">
            {{#if @custom.about_location}}
            <div class="bc-about-fact">
                <div class="bc-about-fact-label">{{t "Based in"}}</div>
                <div class="bc-about-fact-value">{{@custom.about_location}}</div>
            </div>
            {{/if}}
            {{#if @custom.about_day_job}}
            <div class="bc-about-fact bc-about-fact--mid">
                <div class="bc-about-fact-label">{{t "Day job"}}</div>
                <div class="bc-about-fact-value">{{@custom.about_day_job}}</div>
            </div>
            {{/if}}
            {{#if @custom.about_writing_since}}
            <div class="bc-about-fact">
                <div class="bc-about-fact-label">{{t "Writing since"}}</div>
                <div class="bc-about-fact-value">{{@custom.about_writing_since}}</div>
            </div>
            {{/if}}
        </div>

        {{! What I do — from page content (add HTML card in Ghost editor) }}
        <div class="bc-about-section bc-reveal">
            <div class="bc-about-section-label">{{t "What I do"}}</div>
            <div class="bc-about-section-body">
                {{content}}
            </div>
        </div>

        {{! The name }}
        {{#if @custom.about_name_explanation}}
        <div class="bc-about-section bc-reveal">
            <div class="bc-about-section-label">{{t "The name"}}</div>
            <div class="bc-about-section-body">
                <p class="bc-about-name-text">{{@custom.about_name_explanation}}</p>
            </div>
        </div>
        {{/if}}

        {{! Currently into }}
        {{#if @custom.about_currently_into}}
        <div class="bc-about-section bc-reveal">
            <div class="bc-about-section-label">{{t "Currently into"}}</div>
            <div class="bc-about-currently-into" id="bc-about-interests"></div>
        </div>
        <script>
        (function () {
            var raw = {{json @custom.about_currently_into}};
            if (!raw) return;
            var items = raw.split('|').map(function(s){ return s.trim(); }).filter(Boolean);
            var el = document.getElementById('bc-about-interests');
            items.forEach(function (item) {
                var span = document.createElement('span');
                span.className = 'bc-about-interest';
                span.textContent = item;
                el.appendChild(span);
            });
        })();
        </script>
        {{/if}}

        {{! Coding now teaser — Wakatime summary + link to Now page }}
        {{#if @custom.github_username}}
        <div class="bc-about-coding-now bc-reveal">
            <div class="bc-about-coding-now-label">{{t "Coding now"}}</div>
            <div>
                <p class="bc-about-coding-now-text" id="bc-about-coding-now-text">Loading coding stats&hellip;</p>
                <a class="bc-about-coding-now-link" href="/now">{{t "See what I'm building now"}} &rarr;</a>
            </div>
        </div>
        <script>
        (function () {
            function secToHm(s) {
                var h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60);
                return h > 0 ? h + 'h' + (m > 0 ? ' ' + m + 'm' : '') : m + 'm';
            }
            fetch('/api/wakatime/users/current/stats/last_7_days')
                .then(function (r) { if (!r.ok) throw new Error('waka'); return r.json(); })
                .then(function (json) {
                    var data = json.data;
                    if (!data) return;
                    var hrs = Math.round(data.total_seconds / 3600);
                    var topLang = data.languages && data.languages[0] ? data.languages[0].name : '';
                    var topProject = data.projects && data.projects[0] ? data.projects[0].name : '';
                    var text = hrs + ' hrs of code last week.';
                    if (topLang) text += ' Mostly ' + topLang;
                    if (topProject) text += ', on ' + topProject;
                    text += '.';
                    var el = document.getElementById('bc-about-coding-now-text');
                    if (el) el.textContent = text;
                })
                .catch(function () {
                    var el = document.getElementById('bc-about-coding-now-text');
                    if (el) el.textContent = 'Tracking coding activity on the Now page.';
                });
        })();
        </script>
        {{/if}}

    </div>
</main>
{{/post}}
