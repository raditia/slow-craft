{{!< default}}

<main class="bc-main">
    {{#post}}
    <article class="bc-article">

        <div class="bc-container bc-container--article">

            <div class="bc-article-back">
                <a class="bc-back-link" href="javascript:history.back()">&larr; {{t "All writing"}}</a>
            </div>

            <header class="bc-article-header">
                {{#if primary_tag}}
                    <a class="bc-tag-label" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
                {{/if}}
                <h1 class="bc-article-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="bc-article-excerpt">{{custom_excerpt}}</p>
                {{/if}}
                <div class="bc-article-byline">
                    <div class="bc-byline-left">
                        {{#if primary_author.profile_image}}
                            <img class="bc-author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}">
                        {{/if}}
                        <div class="bc-byline-info">
                            <span class="bc-byline-name">{{primary_author.name}}</span>
                            <div class="bc-byline-meta">
                                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                                <span class="bc-meta-dot"></span>
                                <span>{{reading_time}}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            {{#if feature_image}}
                <figure class="bc-article-image">
                    <img
                        srcset="{{img_url feature_image size="s"}} 300w,
                                {{img_url feature_image size="m"}} 720w,
                                {{img_url feature_image size="l"}} 960w,
                                {{img_url feature_image size="xl"}} 1200w"
                        sizes="(max-width: 760px) 100vw, 760px"
                        src="{{img_url feature_image size="l"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    >
                    {{#if feature_image_caption}}
                        <figcaption>{{feature_image_caption}}</figcaption>
                    {{/if}}
                </figure>
            {{/if}}

            <section class="bc-article-content gh-content">
                {{content}}
            </section>

            <div class="bc-author-bio">
                {{#if primary_author.profile_image}}
                    <img class="bc-author-bio-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}">
                {{/if}}
                <div>
                    <div class="bc-author-bio-name">{{t "Written by"}} {{primary_author.name}}</div>
                    {{#if primary_author.bio}}
                        <p class="bc-author-bio-text">{{primary_author.bio}}</p>
                    {{/if}}
                </div>
            </div>

            <div class="bc-read-more bc-reveal">
                <span class="bc-read-more-label">{{t "Keep reading"}}</span>
                <a class="bc-read-more-link" href="{{@site.url}}">
                    <h3 class="bc-read-more-title">{{t "Browse all essays & field notes"}}</h3>
                    <span class="bc-read-more-arrow">&rarr;</span>
                </a>
            </div>

        </div>

    </article>

    {{> "comments"}}

    {{/post}}
</main>
